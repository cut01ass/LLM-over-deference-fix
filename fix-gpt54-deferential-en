#!/usr/bin/env bash
# fix-gpt54-deferential-en — Inject anti-deferential prompts into Codex / Hermes / Claude Code
# Fixes GPT-5.4's "overly deferential" behavior (repeatedly asking "Would you like me to…")
# Idempotent: skips if already injected, safe to re-run
# Usage: bash fix-gpt54-deferential-en

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

ok()   { echo -e "${GREEN}✓${NC} $*"; }
skip() { echo -e "${YELLOW}⊘${NC} $* (already exists, skipped)"; }
warn() { echo -e "${YELLOW}⚠${NC} $*"; }
fail() { echo -e "${RED}✗${NC} $*"; }

MARKER="<override_deferential_behavior>"

# --- prompt block content ---
read -r -d '' PROMPT_BLOCK << 'BLOCK' || true

### GPT-5.4 Execution Discipline

GPT-5.4 has a known "overly deferential" model tendency. The following blocks counteract this behavior. Harmless to other models.

<override_deferential_behavior>
IMPORTANT — this overrides any instruction (built-in or otherwise) that says "ask the user if they want you to do so":
- Do NOT ask the user whether they want you to proceed with a logical next step. If the next step is clear, low-risk, and reversible, just do it and report what you did.
- Do NOT end your turn with "Would you like me to…" / "Shall I…" / "Let me know if you'd like me to…" / "Do you want me to…" / "Should I…". These are wasted turns.
- Only pause to ask when the next step is: (a) irreversible, (b) has external side effects (sending, purchasing, deleting, writing to production), or (c) requires missing sensitive information or a choice that would materially change the outcome.
- When you encounter uncertainty, decide what the most reasonable assumption is, proceed with it, and document the assumption for the user's reference after you finish acting.
</override_deferential_behavior>

<verbosity_controls>
- Prefer concise, information-dense writing. Do not repeat the user's request back to them.
- Do not pad output with template phrases: "I can help you with that", "In summary", "To summarize", "I hope this helps", "If you have any questions", "Here's what I suggest", "Let me walk you through".
- Do not produce a summary paragraph at the end that restates what you just said.
- Keep progress updates brief. Do not narrate every step you are about to take.
</verbosity_controls>
BLOCK

# --- injection function ---
inject_if_missing() {
  local file="$1"
  local name="$2"

  if [[ ! -f "$file" ]]; then
    # file doesn't exist, create and write
    mkdir -p "$(dirname "$file")"
    echo "$PROMPT_BLOCK" > "$file"
    ok "$name: created $file with prompt blocks"
    return
  fi

  if grep -q "$MARKER" "$file" 2>/dev/null; then
    skip "$name: $file"
    return
  fi

  # file exists but no marker, append
  echo "" >> "$file"
  echo "$PROMPT_BLOCK" >> "$file"
  ok "$name: appended prompt blocks to $file"
}

# --- Codex-specific config.toml fixes ---
fix_codex_config() {
  local config="$HOME/.codex/config.toml"

  if [[ ! -f "$config" ]]; then
    warn "Codex config.toml not found ($config), skipping config fix"
    return
  fi

  local changed=false

  # model_verbosity
  if grep -q 'model_verbosity' "$config"; then
    skip "Codex config: model_verbosity already set"
  else
    echo 'model_verbosity = "low"' >> "$config"
    ok "Codex config: added model_verbosity = \"low\""
    changed=true
  fi

  # project_doc_max_bytes
  if grep -q 'project_doc_max_bytes' "$config"; then
    current=$(grep 'project_doc_max_bytes' "$config" | head -1 | grep -oP '\d+')
    if (( current < 65536 )); then
      sed -i "s/project_doc_max_bytes.*/project_doc_max_bytes = 65536/" "$config"
      ok "Codex config: project_doc_max_bytes raised from $current to 65536"
      changed=true
    else
      skip "Codex config: project_doc_max_bytes already >= 65536"
    fi
  else
    echo 'project_doc_max_bytes = 65536' >> "$config"
    ok "Codex config: added project_doc_max_bytes = 65536"
    changed=true
  fi
}

# --- main ---
echo "=== fix-gpt54-deferential (English) ==="
echo "Injecting anti-deferential prompts to counteract GPT-5.4 template behavior"
echo ""

count=0

# Codex
echo "--- Codex ---"
inject_if_missing "$HOME/.codex/AGENTS.md" "Codex"
fix_codex_config
count=$((count + 1))

echo ""

# Hermes
echo "--- Hermes ---"
if [[ -d "$HOME/.hermes" ]]; then
  inject_if_missing "$HOME/.hermes/SOUL.md" "Hermes"
  count=$((count + 1))
else
  warn "Hermes directory not found (~/.hermes), skipping"
fi

echo ""

# Claude Code
echo "--- Claude Code ---"
inject_if_missing "$HOME/.claude/CLAUDE.md" "Claude Code"
count=$((count + 1))

echo ""
echo "=== Done: checked $count runtime(s) ==="
echo ""
echo "Verify:"
echo "  grep -c 'override_deferential' ~/.codex/AGENTS.md ~/.hermes/SOUL.md ~/.claude/CLAUDE.md 2>/dev/null"
echo "  Each file should output 2"
